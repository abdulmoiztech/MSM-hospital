{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["name", "email", "createdAt"]
    },
    "booking": {
      "title": "Appointment Booking",
      "description": "Stores details of a medical appointment booking.",
      "type": "object",
      "properties": {
        "patientName": { "type": "string", "description": "The name of the patient." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "email": { "type": "string", "format": "email", "description": "Contact email address." },
        "department": { "type": "string", "description": "The department for the appointment." },
        "doctor": { "type": "string", "description": "The selected doctor." },
        "preferredDate": { "type": "string", "format": "date", "description": "The date of the appointment." },
        "preferredTime": { "type": "string", "description": "Preferred time slot (morning/afternoon/evening)." },
        "message": { "type": "string", "description": "Additional notes or symptoms." },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled"], "description": "Current status of the appointment." },
        "userId": { "type": "string", "description": "The ID of the user who made the booking." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created." }
      },
      "required": ["patientName", "phone", "email", "department", "doctor", "preferredDate", "preferredTime", "status", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user profiles."
    },
    "/bookings/{bookingId}": {
      "schema": "booking",
      "description": "Collection of appointment bookings."
    }
  }
}
