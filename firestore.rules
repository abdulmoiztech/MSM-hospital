rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'moiz56091@gmail.com' && request.auth.token.email_verified == true;
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.createdAt == request.time;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['patientName', 'phone', 'email', 'department', 'doctor', 'preferredDate', 'preferredTime', 'status', 'userId', 'createdAt']) &&
             (data.keys().size() == 10 || data.keys().size() == 11) &&
             data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 100 &&
             data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 25 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.department is string && data.department.size() > 0 && data.department.size() <= 100 &&
             data.doctor is string && data.doctor.size() > 0 && data.doctor.size() <= 100 &&
             data.preferredDate is string && data.preferredDate.size() > 0 &&
             data.preferredTime is string && data.preferredTime.size() > 0 &&
             data.status in ['Pending', 'Confirmed', 'Cancelled'] &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.createdAt == request.time &&
             (!('message' in data) || (data.message is string && data.message.size() <= 1000));
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // Collection: Bookings
    match /bookings/{bookingId} {
      allow create: if isSignedIn() && isValidBooking(incoming()) && isValidId(bookingId) && incoming().status == 'Pending';
      allow update: if isAdmin() && isValidBooking(incoming());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
